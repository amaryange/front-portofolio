                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledAt\": \"2026-04-01T10:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "Supprimer (corbeille)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/admin/posts/{{postId}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Restaurer",

              "mode": "raw",
              "raw": "{\n  \"title\": \"Mon premier article\",\n  \"locale\": \"fr\",\n  \"content\": \"Contenu de l'article en markdown.\",\n  \"description\": \"Une courte description.\",\n  \"status\": \"draft\",\n  \"tags\": [\"adonis\", \"typescript\"]\n}"
            }
          }
        },
        {

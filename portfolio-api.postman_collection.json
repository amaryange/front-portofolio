                "value": "{{apiKey}}"
              }
            ]
          }
        },
        {
          "name": "Tags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tags",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ]
          }
        }
      ]
    },
